# Kimi API 配置
# 请填入你的 Moonshot AI API Key
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 基础 URL (通常不需要修改)
# KIMI_BASE_URL=https://api.kimi.com/coding/v1

# 网关服务配置
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8765

# 调试模式：记录每次请求与响应 JSON 到 JSONL 文件
GATEWAY_DEBUG=false
GATEWAY_DEBUG_JSONL_FILE=./logs/gateway_requests.jsonl
